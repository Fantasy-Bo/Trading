# Copy these values into Streamlit Community Cloud -> App -> Settings -> Secrets.
# Do not rename this file to secrets.toml and commit real keys.

# Optional login. Set APP_PASSWORD to require a password before the app loads.
APP_USERNAME = ""
APP_PASSWORD = "change-me-before-deploy"

# LLM providers. Fill only the providers you actually use.
OPENAI_API_KEY = ""
GOOGLE_API_KEY = ""
ANTHROPIC_API_KEY = ""
XAI_API_KEY = ""
DEEPSEEK_API_KEY = ""
DASHSCOPE_API_KEY = ""
ZHIPU_API_KEY = ""
MINIMAX_API_KEY = ""
OPENROUTER_API_KEY = ""

# Optional third-party / proxy endpoint.
BACKEND_URL = ""

# Optional market data provider.
ALPHA_VANTAGE_API_KEY = ""
